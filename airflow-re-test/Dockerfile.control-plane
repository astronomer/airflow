FROM ghcr.io/apache/airflow/main/ci/python3.10:latest

USER root

# Remove non-essential provider packages. Keep:
#   - celery (needed for CeleryExecutor)
#   - standard (core dependency — skipmixin, sensors, etc.)
#   - common-compat, common-io, common-sql (shared foundations)
RUN pip uninstall -y --no-input \
    $(pip list | grep 'apache-airflow-providers' \
      | grep -v -E 'celery|standard|common-compat|common-io|common-sql' \
      | awk '{print $1}') 2>/dev/null || true

RUN chmod 1777 /tmp

WORKDIR /opt/airflow

# Replace the CI entrypoint (which does `exec /bin/bash "$@"`) with one
# that does `exec airflow "$@"` so subcommands like `scheduler` work.
COPY airflow-re-test/entrypoint-service.sh /entrypoint-service.sh
RUN chmod +x /entrypoint-service.sh

ENTRYPOINT ["/usr/bin/dumb-init", "--", "/entrypoint-service.sh"]
CMD ["version"]
