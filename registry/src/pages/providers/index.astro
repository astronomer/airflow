---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProviderCard from '../../components/ProviderCard.astro';
import providersData from '../../data/providers.json';

// Transform snake_case keys to camelCase for the frontend
const transformProvider = (p: any) => ({
  ...p,
  packageName: p.package_name,
  airflowVersions: p.airflow_versions,
  qualityScore: p.quality_score,
  pypiDownloads: p.pypi_downloads,
  moduleCounts: p.module_counts,
  relatedProviders: p.related_providers,
  docsUrl: p.docs_url,
  sourceUrl: p.source_url,
  pypiUrl: p.pypi_url,
  lastUpdated: p.last_updated,
});

const providers = providersData.providers.map(transformProvider);

// Get unique tiers
const tiers = ['all', 'official', 'community'] as const;
---

<BaseLayout title="Providers" description="Browse all Apache Airflow providers">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-100 mb-2">Providers</h1>
      <p class="text-gray-400">Browse {providers.length} official and community providers</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-col sm:flex-row gap-4 mb-8">
      <!-- Search -->
      <div class="flex-1">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="provider-search"
            placeholder="Search providers..."
            class="search-input pl-10"
          />
        </div>
      </div>

      <!-- Tier filter -->
      <div class="flex items-center gap-2">
        <span class="text-sm text-gray-500">Tier:</span>
        <div class="flex items-center gap-1 bg-navy-800 border border-navy-600 rounded-lg p-1">
          {tiers.map((tier) => (
            <button
              class={`tier-filter px-3 py-1.5 text-sm rounded-md transition-colors ${
                tier === 'all' ? 'bg-cyan-500 text-navy-900 font-medium' : 'text-gray-400 hover:text-white'
              }`}
              data-tier={tier}
            >
              {tier.charAt(0).toUpperCase() + tier.slice(1)}
            </button>
          ))}
        </div>
      </div>

      <!-- Sort -->
      <div class="flex items-center gap-2">
        <span class="text-sm text-gray-500">Sort:</span>
        <select id="provider-sort" class="bg-navy-800 border border-navy-600 rounded-lg px-3 py-2 text-sm text-gray-300 focus:outline-none focus:border-cyan-500">
          <option value="downloads">Most Downloads</option>
          <option value="name">Name A-Z</option>
          <option value="updated">Recently Updated</option>
          <option value="score">Quality Score</option>
        </select>
      </div>
    </div>

    <!-- Provider grid -->
    <div id="provider-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {providers.map((provider) => (
        <div class="provider-item" data-tier={provider.tier} data-name={provider.name.toLowerCase()} data-downloads={provider.pypiDownloads.monthly} data-score={provider.qualityScore}>
          <ProviderCard provider={provider} />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-16">
      <svg class="w-16 h-16 mx-auto text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="text-gray-400 text-lg">No providers found matching your criteria</p>
    </div>
  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('provider-search') as HTMLInputElement;
  const tierButtons = document.querySelectorAll('.tier-filter');
  const sortSelect = document.getElementById('provider-sort') as HTMLSelectElement;
  const providerGrid = document.getElementById('provider-grid');
  const emptyState = document.getElementById('empty-state');
  const providerItems = document.querySelectorAll('.provider-item') as NodeListOf<HTMLElement>;

  let currentTier = 'all';
  let currentSearch = '';

  function filterAndSort() {
    let visibleCount = 0;

    providerItems.forEach((item) => {
      const tier = item.dataset.tier;
      const name = item.dataset.name || '';

      const matchesTier = currentTier === 'all' || tier === currentTier;
      const matchesSearch = name.includes(currentSearch.toLowerCase());

      if (matchesTier && matchesSearch) {
        item.style.display = 'block';
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });

    // Show/hide empty state
    if (emptyState && providerGrid) {
      if (visibleCount === 0) {
        emptyState.classList.remove('hidden');
        providerGrid.classList.add('hidden');
      } else {
        emptyState.classList.add('hidden');
        providerGrid.classList.remove('hidden');
      }
    }
  }

  // Search handler
  searchInput?.addEventListener('input', (e) => {
    currentSearch = (e.target as HTMLInputElement).value;
    filterAndSort();
  });

  // Tier filter handler
  tierButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      tierButtons.forEach((b) => {
        b.classList.remove('bg-cyan-500', 'text-navy-900', 'font-medium');
        b.classList.add('text-gray-400');
      });
      btn.classList.add('bg-cyan-500', 'text-navy-900', 'font-medium');
      btn.classList.remove('text-gray-400');

      currentTier = (btn as HTMLElement).dataset.tier || 'all';
      filterAndSort();
    });
  });

  // Sort handler
  sortSelect?.addEventListener('change', () => {
    const items = Array.from(providerItems);
    const sortBy = sortSelect.value;

    items.sort((a, b) => {
      switch (sortBy) {
        case 'downloads':
          return Number(b.dataset.downloads) - Number(a.dataset.downloads);
        case 'name':
          return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        case 'score':
          return Number(b.dataset.score) - Number(a.dataset.score);
        default:
          return 0;
      }
    });

    items.forEach((item) => providerGrid?.appendChild(item));
  });
</script>
