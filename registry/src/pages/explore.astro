---
import BaseLayout from '../layouts/BaseLayout.astro';
import providersData from '../data/providers.json';

// Use Astro's base URL for all internal links
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Transform providers
const allProviders = providersData.providers.map((p: any) => ({
  id: p.id,
  name: p.name,
  tier: p.tier,
  logo: p.logo,
  description: p.description,
  moduleCounts: p.module_counts || {},
  totalModules: p.module_counts ? Object.values(p.module_counts as Record<string, number>).reduce((a: number, b: number) => a + b, 0) : 0,
}));

// Group providers by common use cases with better matching
const categories = [
  {
    id: 'cloud',
    name: 'Cloud Platforms',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>`,
    color: 'cyan',
    keywords: ['amazon', 'google', 'microsoft-azure', 'alibaba', 'yandex', 'oracle'],
    description: 'AWS, GCP, Azure, and other cloud providers',
  },
  {
    id: 'databases',
    name: 'Databases',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" /></svg>`,
    color: 'blue',
    keywords: ['postgres', 'mysql', 'mongo', 'redis', 'neo4j', 'elasticsearch', 'cassandra', 'couchbase', 'influxdb', 'sqlite', 'odbc', 'jdbc', 'common-sql'],
    description: 'SQL, NoSQL, and time-series databases',
  },
  {
    id: 'data-warehouses',
    name: 'Data Warehouses',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`,
    color: 'purple',
    keywords: ['snowflake', 'databricks', 'teradata', 'vertica', 'trino', 'presto', 'dbt'],
    description: 'Snowflake, Databricks, and analytics platforms',
  },
  {
    id: 'messaging',
    name: 'Messaging & Notifications',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>`,
    color: 'green',
    keywords: ['slack', 'sendgrid', 'smtp', 'discord', 'telegram', 'pagerduty', 'opsgenie', 'twilio'],
    description: 'Slack, email, SMS, and alerting services',
  },
  {
    id: 'ai-ml',
    name: 'AI & Machine Learning',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`,
    color: 'amber',
    keywords: ['openai', 'cohere', 'anthropic', 'huggingface', 'mlflow', 'pinecone', 'qdrant', 'weaviate', 'pgvector'],
    description: 'OpenAI, vector DBs, and ML platforms',
  },
  {
    id: 'orchestration',
    name: 'Workflow & Orchestration',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    color: 'rose',
    keywords: ['standard', 'celery', 'docker', 'kubernetes', 'ssh', 'http', 'ftp', 'sftp'],
    description: 'Core operators, executors, and connectivity',
  },
];

// Match providers to categories
const categorizedProviders = categories.map(cat => ({
  ...cat,
  providers: allProviders.filter((p: any) =>
    cat.keywords.some(k => p.id.includes(k) || k.includes(p.id))
  ).slice(0, 6),
}));

// Color mappings for Tailwind classes
const colorClasses: Record<string, { bg: string; text: string; border: string; hoverBg: string }> = {
  cyan: { bg: 'bg-cyan-500/20', text: 'text-cyan-400', border: 'border-cyan-500/30', hoverBg: 'hover:bg-cyan-500/30' },
  blue: { bg: 'bg-blue-500/20', text: 'text-blue-400', border: 'border-blue-500/30', hoverBg: 'hover:bg-blue-500/30' },
  purple: { bg: 'bg-purple-500/20', text: 'text-purple-400', border: 'border-purple-500/30', hoverBg: 'hover:bg-purple-500/30' },
  green: { bg: 'bg-green-500/20', text: 'text-green-400', border: 'border-green-500/30', hoverBg: 'hover:bg-green-500/30' },
  amber: { bg: 'bg-amber-500/20', text: 'text-amber-400', border: 'border-amber-500/30', hoverBg: 'hover:bg-amber-500/30' },
  rose: { bg: 'bg-rose-500/20', text: 'text-rose-400', border: 'border-rose-500/30', hoverBg: 'hover:bg-rose-500/30' },
};

// Official providers (pre-installed with Airflow)
const featuredProviders = allProviders
  .filter((p: any) => p.tier === 'official')
  .sort((a: any, b: any) => b.totalModules - a.totalModules)
  .slice(0, 4);

// Community highlights
const communityHighlights = allProviders
  .filter((p: any) => p.tier === 'community' && p.totalModules > 5)
  .sort((a: any, b: any) => b.totalModules - a.totalModules)
  .slice(0, 4);
---

<BaseLayout title="Explore" description="Discover Airflow providers by category and use case">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero -->
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-100 mb-4">Explore by Category</h1>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Find the right providers for your data pipelines. Browse by use case or discover community contributions.
      </p>
    </div>

    <!-- Category Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {categorizedProviders.map((cat) => {
        const colors = colorClasses[cat.color];
        return (
          <div class={`card p-6 border ${colors.border}`}>
            <div class="flex items-center gap-3 mb-4">
              <div class={`w-10 h-10 rounded-lg ${colors.bg} flex items-center justify-center ${colors.text}`} set:html={cat.icon} />
              <div>
                <h3 class="font-semibold text-gray-100">{cat.name}</h3>
                <p class="text-xs text-gray-500">{cat.providers.length}+ providers</p>
              </div>
            </div>
            <p class="text-sm text-gray-400 mb-4">{cat.description}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {cat.providers.map((p: any) => (
                <a
                  href={`${base}/providers/${p.id}`}
                  class={`inline-flex items-center gap-1.5 px-2.5 py-1 text-sm rounded-lg ${colors.bg} ${colors.hoverBg} ${colors.text} transition-colors`}
                >
                  {p.logo && (
                    <img src={`${base}${p.logo}`} alt="" class="w-4 h-4 rounded object-contain" />
                  )}
                  {p.name}
                </a>
              ))}
            </div>
            <a
              href={`${base}/providers?category=${cat.id}`}
              class="text-sm text-gray-400 hover:text-cyan-400 transition-colors inline-flex items-center gap-1"
            >
              View all in {cat.name}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        );
      })}
    </div>

    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Featured Official Providers -->
      <div class="card p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-gray-100">Official Providers</h2>
          <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-cyan-500/20 text-cyan-400">Pre-installed</span>
        </div>
        <div class="space-y-3">
          {featuredProviders.map((p: any) => (
            <a
              href={`${base}/providers/${p.id}`}
              class="flex items-center gap-4 p-3 rounded-lg hover:bg-navy-700/50 transition-colors group"
            >
              <div class="w-10 h-10 rounded-lg bg-navy-700 flex items-center justify-center flex-shrink-0 overflow-hidden">
                {p.logo ? (
                  <img src={`${base}${p.logo}`} alt={p.name} class="w-8 h-8 object-contain" />
                ) : (
                  <span class="text-lg font-bold text-cyan-400">{p.name.charAt(0)}</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-medium text-gray-100 group-hover:text-cyan-400 transition-colors">{p.name}</div>
                <div class="text-xs text-gray-500 truncate">{p.description}</div>
              </div>
              <div class="text-sm text-gray-400">{p.totalModules} {p.totalModules === 1 ? 'module' : 'modules'}</div>
            </a>
          ))}
        </div>
        <a
          href="${base}/providers?tier=official"
          class="mt-4 block text-center text-sm text-gray-400 hover:text-cyan-400 transition-colors"
        >
          View all official providers →
        </a>
      </div>

      <!-- Community Highlights -->
      <div class="card p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-gray-100">Community Highlights</h2>
          <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-gray-500/20 text-gray-400">Community</span>
        </div>
        <div class="space-y-3">
          {communityHighlights.map((p: any) => (
            <a
              href={`${base}/providers/${p.id}`}
              class="flex items-center gap-4 p-3 rounded-lg hover:bg-navy-700/50 transition-colors group"
            >
              <div class="w-10 h-10 rounded-lg bg-navy-700 flex items-center justify-center flex-shrink-0 overflow-hidden">
                {p.logo ? (
                  <img src={`${base}${p.logo}`} alt={p.name} class="w-8 h-8 object-contain" />
                ) : (
                  <span class="text-lg font-bold text-gray-400">{p.name.charAt(0)}</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-medium text-gray-100 group-hover:text-cyan-400 transition-colors">{p.name}</div>
                <div class="text-xs text-gray-500 truncate">{p.description}</div>
              </div>
              <div class="text-sm text-gray-400">{p.totalModules} {p.totalModules === 1 ? 'module' : 'modules'}</div>
            </a>
          ))}
        </div>
        <a
          href="${base}/providers?tier=community"
          class="mt-4 block text-center text-sm text-gray-400 hover:text-cyan-400 transition-colors"
        >
          View all community providers →
        </a>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="mt-12 text-center">
      <p class="text-gray-400 mb-4">Looking for something specific?</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="${base}/providers" class="btn-secondary">
          All Providers
        </a>
        <a href="${base}/stats" class="btn-secondary">
          View Statistics
        </a>
        <button id="open-search" class="btn-primary inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Search Modules
        </button>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('open-search')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('open-command-palette'));
    });
  </script>
</BaseLayout>
