---
import BaseLayout from '../layouts/BaseLayout.astro';
import providersData from '../data/providers.json';

// Use Astro's base URL for all internal links
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Calculate aggregate statistics
const providers = providersData.providers;

// Total counts
const totalProviders = providers.length;

// Count by tier
const tierCounts: Record<string, number> = providers.reduce((acc: Record<string, number>, p: any) => {
  acc[p.tier] = (acc[p.tier] || 0) + 1;
  return acc;
}, {});

// Prepare tier data for display
const tierStyles: Record<string, { bg: string; text: string }> = {
  official: { bg: 'bg-cyan-500', text: 'text-cyan-400' },
  community: { bg: 'bg-gray-500', text: 'text-gray-400' },
};

const tierDisplayData = Object.entries(tierCounts).map(([tier, count]) => ({
  tier,
  count,
  percentage: (count / totalProviders * 100).toFixed(1),
  style: tierStyles[tier] || tierStyles.community,
}));

// Sum all module counts across all providers
const aggregateModuleCounts: Record<string, number> = providers.reduce((acc: Record<string, number>, p: any) => {
  if (p.module_counts) {
    Object.entries(p.module_counts).forEach(([type, count]) => {
      acc[type] = (acc[type] || 0) + (count as number);
    });
  }
  return acc;
}, {});

const totalModules = Object.values(aggregateModuleCounts).reduce((a: number, b: number) => a + b, 0);

// Top providers by module count
const topProvidersByModules = [...providers]
  .map((p: any) => ({
    ...p,
    totalModules: p.module_counts ? Object.values(p.module_counts).reduce((a: number, b: any) => a + b, 0) : 0
  }))
  .sort((a: any, b: any) => b.totalModules - a.totalModules)
  .slice(0, 10);

// Module type metadata for display
const moduleTypeInfo: Record<string, { label: string; icon: string; color: string; bgColor: string }> = {
  operator: {
    label: 'Operators',
    icon: 'O',
    color: 'text-green-400',
    bgColor: 'bg-green-500/20',
  },
  hook: {
    label: 'Hooks',
    icon: 'H',
    color: 'text-blue-400',
    bgColor: 'bg-blue-500/20',
  },
  sensor: {
    label: 'Sensors',
    icon: 'S',
    color: 'text-amber-400',
    bgColor: 'bg-amber-500/20',
  },
  trigger: {
    label: 'Triggers',
    icon: 'T',
    color: 'text-purple-400',
    bgColor: 'bg-purple-500/20',
  },
  transfer: {
    label: 'Transfers',
    icon: 'X',
    color: 'text-pink-400',
    bgColor: 'bg-pink-500/20',
  },
  notifier: {
    label: 'Notifiers',
    icon: 'N',
    color: 'text-indigo-400',
    bgColor: 'bg-indigo-500/20',
  },
  secret: {
    label: 'Secrets Backend',
    icon: 'K',
    color: 'text-rose-400',
    bgColor: 'bg-rose-500/20',
  },
  logging: {
    label: 'Log Handlers',
    icon: 'L',
    color: 'text-teal-400',
    bgColor: 'bg-teal-500/20',
  },
  executor: {
    label: 'Executors',
    icon: 'E',
    color: 'text-orange-400',
    bgColor: 'bg-orange-500/20',
  },
  decorator: {
    label: 'Decorators',
    icon: '@',
    color: 'text-fuchsia-400',
    bgColor: 'bg-fuchsia-500/20',
  },
};

// Prepare module type display data
const moduleTypeDisplayData = Object.entries(moduleTypeInfo).map(([type, info]) => ({
  type,
  ...info,
  count: aggregateModuleCounts[type] || 0,
  percentage: totalModules > 0 ? ((aggregateModuleCounts[type] || 0) / totalModules * 100) : 0,
}));
---

<BaseLayout title="Statistics">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-100 mb-2">Registry Statistics</h1>
      <p class="text-gray-400">Overview of all Airflow providers and modules in the ecosystem</p>
    </div>

    <!-- Main stats cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <!-- Total Providers -->
      <div class="card p-6 text-center">
        <div class="text-4xl font-bold text-cyan-400 mb-2">{totalProviders}</div>
        <div class="text-gray-400 text-sm font-medium">Total Providers</div>
      </div>

      <!-- Total Modules -->
      <div class="card p-6 text-center">
        <div class="text-4xl font-bold text-cyan-400 mb-2">{totalModules.toLocaleString()}</div>
        <div class="text-gray-400 text-sm font-medium">Total Modules</div>
      </div>

      <!-- Official Providers -->
      <div class="card p-6 text-center">
        <div class="text-4xl font-bold text-cyan-400 mb-2">{tierCounts.official || 0}</div>
        <div class="text-gray-400 text-sm font-medium">Official Providers</div>
      </div>

      <!-- Community Providers -->
      <div class="card p-6 text-center">
        <div class="text-4xl font-bold text-cyan-400 mb-2">{tierCounts.community || 0}</div>
        <div class="text-gray-400 text-sm font-medium">Community Providers</div>
      </div>
    </div>

    <!-- Module Types Breakdown -->
    <div class="mb-8">
      <h2 class="text-xl font-semibold text-gray-100 mb-4">Modules by Type</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        {moduleTypeDisplayData.map((item) => (
          <div class="card p-5">
            <div class="flex items-center gap-3 mb-3">
              <div class={`w-10 h-10 rounded-lg ${item.bgColor} flex items-center justify-center`}>
                <span class={`text-lg font-bold ${item.color}`}>{item.icon}</span>
              </div>
              <div>
                <div class="text-2xl font-bold text-gray-100">
                  {item.count.toLocaleString()}
                </div>
              </div>
            </div>
            <div class="text-gray-400 text-sm font-medium">{item.label}</div>
            <div class="mt-2">
              <div class="w-full h-2 bg-navy-700 rounded-full overflow-hidden">
                <div
                  class={`h-full rounded-full ${item.bgColor.replace('/20', '')}`}
                  style={`width: ${item.percentage}%`}
                ></div>
              </div>
              <div class="text-xs text-gray-500 mt-1">
                {item.percentage.toFixed(1)}% of total
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Providers by Tier -->
    <div class="grid md:grid-cols-2 gap-8 mb-8">
      <!-- Tier breakdown -->
      <div class="card p-6">
        <h2 class="text-xl font-semibold text-gray-100 mb-4">Providers by Tier</h2>
        <div class="space-y-4">
          {tierDisplayData.map((item) => (
            <div>
              <div class="flex justify-between mb-1">
                <span class={`font-medium capitalize ${item.style.text}`}>{item.tier}</span>
                <span class="text-gray-400">{item.count} providers ({item.percentage}%)</span>
              </div>
              <div class="w-full h-3 bg-navy-700 rounded-full overflow-hidden">
                <div
                  class={`h-full rounded-full ${item.style.bg}`}
                  style={`width: ${item.percentage}%`}
                ></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Quick links -->
      <div class="card p-6">
        <h2 class="text-xl font-semibold text-gray-100 mb-4">Quick Links</h2>
        <div class="space-y-3">
          <a href="${base}/providers" class="flex items-center justify-between p-3 rounded-lg bg-navy-700 hover:bg-navy-600 transition-colors group">
            <span class="text-gray-100">Browse All Providers</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-cyan-400 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a href="${base}/providers?tier=official" class="flex items-center justify-between p-3 rounded-lg bg-navy-700 hover:bg-navy-600 transition-colors group">
            <span class="text-gray-100">Official Providers Only</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-cyan-400 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a href="${base}/explore" class="flex items-center justify-between p-3 rounded-lg bg-navy-700 hover:bg-navy-600 transition-colors group">
            <span class="text-gray-100">Explore Provider Graph</span>
            <svg class="w-5 h-5 text-gray-500 group-hover:text-cyan-400 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Top Providers by Module Count -->
    <div class="mb-8">
      <h2 class="text-xl font-semibold text-gray-100 mb-4">Top 10 Providers by Module Count</h2>
      <div class="card overflow-hidden">
        <table class="w-full">
          <thead class="bg-navy-700">
            <tr>
              <th class="text-left px-4 py-3 text-sm font-semibold text-gray-300">#</th>
              <th class="text-left px-4 py-3 text-sm font-semibold text-gray-300">Provider</th>
              <th class="text-center px-4 py-3 text-sm font-semibold text-gray-300">
                <span class="hidden sm:inline">Operators</span>
                <span class="sm:hidden">O</span>
              </th>
              <th class="text-center px-4 py-3 text-sm font-semibold text-gray-300">
                <span class="hidden sm:inline">Hooks</span>
                <span class="sm:hidden">H</span>
              </th>
              <th class="text-center px-4 py-3 text-sm font-semibold text-gray-300">
                <span class="hidden sm:inline">Sensors</span>
                <span class="sm:hidden">S</span>
              </th>
              <th class="text-center px-4 py-3 text-sm font-semibold text-gray-300">
                <span class="hidden sm:inline">Triggers</span>
                <span class="sm:hidden">T</span>
              </th>
              <th class="text-center px-4 py-3 text-sm font-semibold text-gray-300">
                <span class="hidden sm:inline">Transfers</span>
                <span class="sm:hidden">X</span>
              </th>
              <th class="text-right px-4 py-3 text-sm font-semibold text-gray-300">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-navy-700">
            {topProvidersByModules.map((provider: any, index: number) => (
              <tr class="hover:bg-navy-800/50 transition-colors">
                <td class="px-4 py-3 text-gray-500">{index + 1}</td>
                <td class="px-4 py-3">
                  <a href={`${base}/providers/${provider.id}`} class="flex items-center gap-2 hover:text-cyan-400 transition-colors">
                    <div class="w-8 h-8 rounded bg-navy-700 flex items-center justify-center flex-shrink-0">
                      <span class="text-sm font-bold text-cyan-400">{provider.name.charAt(0)}</span>
                    </div>
                    <span class="font-medium text-gray-100">{provider.name}</span>
                    <span class={`px-1.5 py-0.5 text-xs rounded-full ${provider.tier === 'official' ? 'badge-official' : 'badge-community'}`}>
                      {provider.tier}
                    </span>
                  </a>
                </td>
                <td class="px-4 py-3 text-center text-green-400 font-medium">{provider.module_counts?.operator || 0}</td>
                <td class="px-4 py-3 text-center text-blue-400 font-medium">{provider.module_counts?.hook || 0}</td>
                <td class="px-4 py-3 text-center text-amber-400 font-medium">{provider.module_counts?.sensor || 0}</td>
                <td class="px-4 py-3 text-center text-purple-400 font-medium">{provider.module_counts?.trigger || 0}</td>
                <td class="px-4 py-3 text-center text-pink-400 font-medium">{provider.module_counts?.transfer || 0}</td>
                <td class="px-4 py-3 text-right font-bold text-cyan-400">{provider.totalModules}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</BaseLayout>
