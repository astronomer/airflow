---
import type { Module, ModuleType } from '../types';
import { MODULE_TYPE_ICONS } from '../types';

interface Props {
  module: Module;
  showProvider?: boolean;
}

const { module, showProvider = true } = Astro.props;

const typeColors: Record<ModuleType, string> = {
  operator: 'bg-green-500/20 text-green-400 border-green-500/30',
  hook: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  sensor: 'bg-amber-500/20 text-amber-400 border-amber-500/30',
  trigger: 'bg-purple-500/20 text-purple-400 border-purple-500/30',
  transfer: 'bg-pink-500/20 text-pink-400 border-pink-500/30',
  notifier: 'bg-rose-500/20 text-rose-400 border-rose-500/30',
  secret: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  logging: 'bg-teal-500/20 text-teal-400 border-teal-500/30',
  executor: 'bg-indigo-500/20 text-indigo-400 border-indigo-500/30',
  decorator: 'bg-orange-500/20 text-orange-400 border-orange-500/30',
};

const typeLabels: Record<ModuleType, string> = {
  operator: 'Operator',
  hook: 'Hook',
  sensor: 'Sensor',
  trigger: 'Trigger',
  transfer: 'Transfer',
  notifier: 'Notifier',
  secret: 'Secrets Backend',
  logging: 'Log Handler',
  executor: 'Executor',
  decorator: 'Decorator',
};
---

<div class="card p-4 group">
  <div class="flex items-start gap-3">
    <!-- Type icon -->
    <div class={`w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 border ${typeColors[module.type]}`}>
      <span class="text-sm font-bold">{MODULE_TYPE_ICONS[module.type]}</span>
    </div>

    <div class="flex-1 min-w-0">
      <!-- Module name -->
      <div class="flex items-center gap-2 mb-1">
        <h4 class="font-semibold text-gray-100 truncate">{module.name}</h4>
      </div>

      <!-- Provider (if showing) -->
      {showProvider && (
        <p class="text-xs text-gray-500 mb-1">{module.providerName}</p>
      )}

      <!-- Description -->
      <p class="text-sm text-gray-400 line-clamp-2 mb-3">{module.shortDescription}</p>

      <!-- Import path -->
      <div class="flex items-center gap-2 import-path-container">
        <code class="import-path-code text-xs font-mono px-2 py-1 rounded truncate flex-1">
          {module.importPath}
        </code>
        <button
          class="copy-btn p-1.5 rounded transition-colors border copy-btn-styled"
          data-copy={`from ${module.importPath} import ${module.name}`}
          title="Copy import statement"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </button>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3 mt-3">
        <a
          href={module.docsUrl}
          target="_blank"
          rel="noopener"
          class="text-xs text-cyan-400 hover:text-cyan-300 flex items-center gap-1 transition-colors"
        >
          View Docs
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <a
          href={module.sourceUrl}
          target="_blank"
          rel="noopener"
          class="text-xs text-gray-500 hover:text-gray-300 flex items-center gap-1 transition-colors"
        >
          Source
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      if (text) {
        await navigator.clipboard.writeText(text);
        // Could add a toast notification here
      }
    });
  });
</script>
