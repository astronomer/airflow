---
import type { Provider } from '../types';
import { formatDownloads, getLifecycleDisplay } from '../types';

// Use Astro's base URL for all internal links
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Props {
  provider: Provider;
}

const { provider } = Astro.props;

const lifecycleDisplay = getLifecycleDisplay(provider.lifecycle || 'production');
const showLifecycleBadge = lifecycleDisplay !== 'stable';

const lifecycleBadgeClass: Record<string, string> = {
  incubation: 'badge-incubation',
  deprecated: 'badge-deprecated',
};

// Calculate module type counts and total
const counts = {
  operator: provider.moduleCounts?.operator || 0,
  hook: provider.moduleCounts?.hook || 0,
  sensor: provider.moduleCounts?.sensor || 0,
  trigger: provider.moduleCounts?.trigger || 0,
  transfer: provider.moduleCounts?.transfer || 0,
};
const totalModules = Object.values(counts).reduce((a, b) => a + b, 0);

// Calculate percentages for the stacked bar
const getPercent = (val: number) => totalModules > 0 ? (val / totalModules) * 100 : 0;
---

<a href={`${base}/providers/${provider.id}`} class="card-interactive block p-5 group">
  <div class="flex items-start gap-4">
    <!-- Logo -->
    <div class="w-12 h-12 rounded-lg bg-navy-700 flex items-center justify-center flex-shrink-0 group-hover:bg-navy-600 transition-colors overflow-hidden">
      {provider.logo ? (
        <img
          src={`${base}${provider.logo}`}
          alt={`${provider.name} logo`}
          class="w-10 h-10 object-contain"
          loading="lazy"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
        />
        <span class="text-xl font-bold text-cyan-400 hidden">{provider.name.charAt(0)}</span>
      ) : (
        <span class="text-xl font-bold text-cyan-400">{provider.name.charAt(0)}</span>
      )}
    </div>

    <div class="flex-1 min-w-0">
      <!-- Header -->
      <div class="flex items-center gap-2 mb-1">
        <h3 class="font-semibold text-lg text-gray-100 truncate">{provider.name}</h3>
        {showLifecycleBadge && (
          <span class={`px-2 py-0.5 text-xs font-medium rounded-full ${lifecycleBadgeClass[lifecycleDisplay]}`}>
            {lifecycleDisplay}
          </span>
        )}
      </div>

      <!-- Package name -->
      <p class="text-sm text-gray-500 font-mono mb-2 truncate">{provider.packageName}</p>

      <!-- Description -->
      <p class="text-sm text-gray-400 line-clamp-2 mb-4">{provider.description}</p>

      <!-- Module Composition - stacked bar with hover tooltips -->
      <div class="mb-3">
        <!-- Stacked bar with count -->
        <div class="flex items-center gap-3">
          <span class="text-sm font-semibold text-gray-200 w-24 flex-shrink-0">{totalModules} modules</span>

          <!-- Stacked bar container with hover tooltips -->
          <div class="flex-1 h-2.5 bg-navy-700/50 rounded-full flex stacked-bar relative">
            {counts.operator > 0 && (
              <div
                class="h-full bg-green-500 hover:brightness-125 transition-all cursor-default bar-segment first:rounded-l-full"
                style={`width: ${getPercent(counts.operator)}%`}
                data-tooltip={`${counts.operator} Operators`}
              />
            )}
            {counts.hook > 0 && (
              <div
                class="h-full bg-blue-500 hover:brightness-125 transition-all cursor-default bar-segment"
                style={`width: ${getPercent(counts.hook)}%`}
                data-tooltip={`${counts.hook} Hooks`}
              />
            )}
            {counts.sensor > 0 && (
              <div
                class="h-full bg-amber-500 hover:brightness-125 transition-all cursor-default bar-segment"
                style={`width: ${getPercent(counts.sensor)}%`}
                data-tooltip={`${counts.sensor} Sensors`}
              />
            )}
            {counts.trigger > 0 && (
              <div
                class="h-full bg-purple-500 hover:brightness-125 transition-all cursor-default bar-segment"
                style={`width: ${getPercent(counts.trigger)}%`}
                data-tooltip={`${counts.trigger} Triggers`}
              />
            )}
            {counts.transfer > 0 && (
              <div
                class="h-full bg-pink-500 hover:brightness-125 transition-all cursor-default bar-segment last:rounded-r-full"
                style={`width: ${getPercent(counts.transfer)}%`}
                data-tooltip={`${counts.transfer} Transfers`}
              />
            )}
          </div>
        </div>
      </div>

      <!-- Stats row -->
      <div class="flex items-center gap-4 text-sm">
        <!-- Downloads -->
        <div class="flex items-center gap-1.5 text-gray-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          <span>{formatDownloads(provider.pypiDownloads.monthly)}/mo</span>
        </div>

        <!-- Airflow versions - inline -->
        <div class="hidden sm:flex items-center gap-1.5 ml-auto">
          {provider.airflowVersions.slice(0, 2).map((version) => (
            <span class="px-1.5 py-0.5 text-xs font-medium bg-navy-700 text-gray-400 rounded border border-navy-600">
              {version}
            </span>
          ))}
          {provider.airflowVersions.length > 2 && (
            <span class="text-xs text-gray-500">+{provider.airflowVersions.length - 2}</span>
          )}
        </div>
      </div>
    </div>

    <!-- Arrow indicator -->
    <svg
      class="w-5 h-5 text-gray-600 group-hover:text-cyan-400 group-hover:translate-x-1 transition-all flex-shrink-0 mt-2"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
