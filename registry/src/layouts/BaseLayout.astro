---
import '../styles/global.css';
import CommandPalette from '../components/CommandPalette';
import ThemeToggle from '../components/ThemeToggle';
import searchData from '../data/search-index.json';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Discover Airflow Providers, Operators, Hooks, Sensors, and more.' } = Astro.props;
const fullTitle = title === 'Home' ? 'Airflow Registry' : `${title} | Airflow Registry`;

// Use Astro's base URL for all internal links
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // Remove trailing slash if present

// Transform the search data to match the expected format
const transformedSearchData = searchData.map((item: any) => ({
  type: item.type,
  id: item.id,
  name: item.name,
  className: item.className,
  description: item.description,
  url: item.url,
  importPath: item.importPath,
  moduleType: item.moduleType,
  providerName: item.providerName,
  providerId: item.providerId,
}));
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <title>{fullTitle}</title>

    <!-- Preconnect to font sources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="header-theme sticky top-0 z-50 border-b backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href={`${base}/`} class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <img src={`${base}/airflow_logo.svg`} alt="Apache Airflow" class="h-8" />
            <span class="text-lg font-medium text-gray-100 opacity-60">|</span>
            <span class="text-lg font-semibold text-gray-100">Registry</span>
          </a>

          <!-- Navigation -->
          <nav class="hidden md:flex items-center gap-6">
            <a href={`${base}/providers`} class="nav-link">Providers</a>
            <a href={`${base}/stats`} class="nav-link">Stats</a>
            <a href={`${base}/explore`} class="nav-link">Explore</a>
            <a href="https://airflow.apache.org/docs/" class="nav-link flex items-center gap-1" target="_blank" rel="noopener">
              Docs
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </nav>

          <!-- Right side controls -->
          <div class="flex items-center gap-2 sm:gap-3">
            <!-- Search shortcut hint -->
            <button
              id="search-trigger"
              class="search-btn flex items-center gap-2 px-2 sm:px-3 py-1.5 rounded-lg border transition-colors hover:border-cyan-500/50"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <span class="text-sm hidden sm:inline">Search...</span>
              <span class="kbd hidden sm:inline">⌘K</span>
            </button>

            <!-- Theme toggle -->
            <ThemeToggle client:load />

            <!-- Mobile menu button -->
            <button
              id="mobile-menu-btn"
              class="mobile-menu-btn md:hidden p-2 rounded-lg border"
              aria-label="Open mobile menu"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile navigation -->
        <nav id="mobile-nav" class="hidden md:hidden pb-4 border-t mobile-nav-theme mt-4 pt-4">
          <div class="flex flex-col gap-3">
            <a href={`${base}/providers`} class="nav-link py-2">Providers</a>
            <a href={`${base}/stats`} class="nav-link py-2">Stats</a>
            <a href={`${base}/explore`} class="nav-link py-2">Explore</a>
            <a href="https://airflow.apache.org/docs/" class="nav-link py-2 flex items-center gap-1" target="_blank" rel="noopener">
              Docs
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </nav>
      </div>
    </header>

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <footer class="footer-theme border-t py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="footer-text text-sm">
            © {new Date().getFullYear()} Apache Airflow. All rights reserved.
          </div>
          <div class="flex items-center gap-6 text-sm">
            <a href="https://github.com/apache/airflow" class="footer-link" target="_blank" rel="noopener">
              GitHub
            </a>
            <a href="https://airflow.apache.org/" class="footer-link" target="_blank" rel="noopener">
              Apache Airflow
            </a>
            <a href="https://airflow.apache.org/community/" class="footer-link" target="_blank" rel="noopener">
              Community
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Command palette -->
    <CommandPalette client:load searchData={transformedSearchData} />

    <script>
      // Keyboard shortcut for search
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          const event = new CustomEvent('open-command-palette');
          document.dispatchEvent(event);
        }
      });

      document.getElementById('search-trigger')?.addEventListener('click', () => {
        const event = new CustomEvent('open-command-palette');
        document.dispatchEvent(event);
      });

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileNav = document.getElementById('mobile-nav');

      mobileMenuBtn?.addEventListener('click', () => {
        const isHidden = mobileNav?.classList.contains('hidden');
        if (isHidden) {
          mobileNav?.classList.remove('hidden');
          mobileMenuBtn.innerHTML = `
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          `;
        } else {
          mobileNav?.classList.add('hidden');
          mobileMenuBtn.innerHTML = `
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          `;
        }
      });

      // Initialize theme from localStorage
      const storedTheme = localStorage.getItem('theme');
      if (storedTheme === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>
  </body>
</html>
