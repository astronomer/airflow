<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'Discover Airflow Providers, Operators, Hooks, Sensors, and more.' }}">
  <link rel="icon" type="image/png" href="/favicon.png">
  <title>{{ title }} | Airflow Registry</title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="header-content">
        <a href="/" class="site-logo">
          <img src="/airflow_logo.svg" alt="Apache Airflow">
          <span class="logo-separator">|</span>
          <span class="logo-text">Registry</span>
        </a>

        <nav class="site-nav">
          <a href="/providers" class="nav-link">Providers</a>
          <a href="/stats" class="nav-link">Stats</a>
          <a href="/explore" class="nav-link">Explore</a>
          <a href="https://airflow.apache.org/docs/" class="nav-link" target="_blank" rel="noopener">
            Docs
            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:inline;vertical-align:middle;margin-left:2px">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </nav>

        <div class="header-actions">
          <button id="search-trigger" class="search-button">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="search-button-text">Search...</span>
            <span class="kbd">⌘K</span>
          </button>

          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
            <svg id="theme-icon-sun" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg id="theme-icon-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>

          <button id="mobile-menu-btn" class="mobile-menu-button" aria-label="Open mobile menu">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <nav id="mobile-nav" class="mobile-nav">
        <a href="/providers" class="nav-link">Providers</a>
        <a href="/stats" class="nav-link">Stats</a>
        <a href="/explore" class="nav-link">Explore</a>
        <a href="https://airflow.apache.org/docs/" class="nav-link" target="_blank" rel="noopener">Docs</a>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-text">
          © {{ year or 2026 }} Apache Airflow. All rights reserved.
        </div>
        <div class="footer-links">
          <a href="https://github.com/apache/airflow" class="footer-link" target="_blank" rel="noopener">GitHub</a>
          <a href="https://airflow.apache.org/" class="footer-link" target="_blank" rel="noopener">Apache Airflow</a>
          <a href="https://airflow.apache.org/community/" class="footer-link" target="_blank" rel="noopener">Community</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="/js/theme.js"></script>
  <script src="/js/mobile-menu.js"></script>
  <script src="/js/copy-button.js"></script>
  <script src="/js/install-widget.js"></script>
</body>
</html>
